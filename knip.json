{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignore": [
    "**/*.css",
    "services/cron/src/jobs/**/*",
    "applications/web/src/generated/**/*"
  ],
  "ignoreBinaries": [],
  "ignoreDependencies": ["pino-opentelemetry-transport"],
  "ignoreWorkspaces": ["packages/typescript-config"],
  "ignoreExportsUsedInFile": true,
  "workspaces": {
    "packages/*": {
      "entry": ["src/{index.ts,api.ts,cron.ts,**/*.test.ts}"],
      "project": "src/**/*.{ts,tsx}"
    },
    "applications/*": {
      "entry": ["src/{index.ts,main.tsx,server.tsx,**/*.test.ts,**/*.test.tsx}"],
      "project": "src/**/*.{ts,tsx}"
    },
    "applications/web": {
      "entry": ["src/main.tsx", "src/server.tsx", "plugins/**/*.ts", "scripts/**/*.ts", "src/**/*.test.ts", "src/**/*.test.tsx"],
      "project": ["src/**/*.{ts,tsx}", "plugins/**/*.ts", "scripts/**/*.ts"],
      "ignoreDependencies": ["@babel/preset-typescript"]
    },
"services/*": {
      "entry": ["src/{index.ts,**/*.test.ts}"],
      "project": "src/**/*.{ts,tsx}"
    },
    "services/api": {
      "entry": ["src/routes/**/*.ts", "src/**/*.test.ts"],
      "project": "src/**/*.{ts,tsx}"
    },
    "services/cron": {
      "entry": ["src/jobs/*.ts", "src/**/*.test.ts"],
      "project": "src/**/*.{ts,tsx}"
    },
    "services/mcp": {
      "entry": ["src/routes/**/*.ts", "src/**/*.test.ts"],
      "project": "src/**/*.{ts,tsx}"
    }
  }
}
