{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "stream",
  "globalPassThroughEnv": ["CI", "ENV", "OTEL_EXPORTER_OTLP_ENDPOINT", "OTEL_EXPORTER_OTLP_PROTOCOL", "OTEL_EXPORTER_OTLP_HEADERS"],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "//#dev:root": {
      "cache": false,
      "persistent": true
    },
    "types": {
      "dependsOn": ["^types"],
      "inputs": ["src/**", "scripts/**", "tsconfig.json", "package.json"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "start": {
      "cache": false
    },
    "migrate": {
      "cache": false
    },
    "test": {
      "cache": false
    },
    "test": {
      "cache": false
    },
    "lint": {
      "inputs": ["src/**", ".oxlintrc.json", "../../.oxlintrc.json"],
      "cache": true
    }
  }
}
