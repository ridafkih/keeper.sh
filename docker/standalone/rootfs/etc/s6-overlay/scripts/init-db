#!/bin/bash
set -e

until su postgres -c "/usr/lib/postgresql/17/bin/pg_isready -q"; do
    sleep 1
done

KEEPER_DB_PASSWORD="${POSTGRES_PASSWORD:-keeper}"

if ! su postgres -c "/usr/lib/postgresql/17/bin/psql -tAc \"SELECT 1 FROM pg_database WHERE datname='keeper'\"" | grep -q 1; then
    su postgres -c "/usr/lib/postgresql/17/bin/createuser -s keeper" || true
    su postgres -c "/usr/lib/postgresql/17/bin/createdb -O keeper keeper"
    su postgres -c "/usr/lib/postgresql/17/bin/psql -c \"ALTER USER keeper WITH PASSWORD '${KEEPER_DB_PASSWORD}'\""
fi

if [ -n "${POSTGRES_PASSWORD}" ]; then
    export DATABASE_URL="postgresql://keeper:${KEEPER_DB_PASSWORD}@localhost:5432/keeper"
fi

/root/.bun/bin/bun /app/packages/database/scripts/migrate.ts
