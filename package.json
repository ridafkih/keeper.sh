{
  "name": "keeper.sh",
  "devDependencies": {
    "knip": "5.80.0",
    "oxlint": "^1.55.0",
    "rimraf": "^6.1.3",
    "turbo": "2.7.3"
  },
  "license": "AGPL-3.0-only",
  "overrides": {
    "arktype": "^2.2.0"
  },
  "packageManager": "bun@1.3.5",
  "private": true,
  "scripts": {
    "clean": "rimraf --glob **/{.turbo,node_modules,.next/}/",
    "dev": "turbo run dev dev:root",
    "dev:root": "docker compose up --force-recreate",
    "types": "turbo run types --parallel",
    "build": "turbo run build",
    "start": "turbo run start",
    "test": "bun run check:test-layout && turbo run test",
    "check:test-layout": "bun scripts/check-test-layout.mjs",
    "lint": "turbo run lint",
    "unused": "knip"
  },
  "type": "module",
  "workspaces": {
    "packages": [
      "packages/*",
      "applications/*",
      "services/*"
    ]
  }
}
